// THÊM ĐOẠN NÀY ĐỂ PRISMA BIẾT ĐƯỜNG SINH CODE CHO NODE.JS
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"  // <-- Thay env("DATABASE_URL") thành chuỗi này
}

model User {
  id        Int        @id @default(autoincrement())
  fullName  String
  email     String     @unique
  password  String
  createdAt DateTime   @default(now())
  
  // Một User có thể có nhiều sản phẩm trong giỏ hàng
  cartItems CartItem[] 
  
  // MỚI: Một User có thể có nhiều Đơn hàng (Lịch sử mua hàng)
  orders    Order[]
}

model Product {
  id        Int        @id @default(autoincrement())
  name      String
  price     String
  sold      String
  image     String
  createdAt DateTime   @default(now())
  
  // Một sản phẩm có thể nằm trong giỏ hàng của nhiều User
  cartItems CartItem[] 
}

model CartItem {
  id        Int      @id @default(autoincrement())
  quantity  Int      @default(1) // Mặc định thêm vào giỏ là 1 cái
  userId    Int
  productId Int
  
  // Liên kết khóa ngoại
  user      User     @relation(fields: [userId], references: [id])
  product   Product  @relation(fields: [productId], references: [id])
  createdAt DateTime @default(now())
}

// ==========================================
// BẢNG MỚI: QUẢN LÝ ĐƠN HÀNG VÀ CHI TIẾT
// ==========================================

model Order {
  id          Int         @id @default(autoincrement())
  orderNumber String      @unique
  totalAmount Float
  createdAt   DateTime    @default(now())
  
  // Liên kết với User (Ai là người đặt đơn này?)
  userId      Int
  user        User        @relation(fields: [userId], references: [id])

  // Một đơn hàng sẽ có nhiều chi tiết (các sản phẩm đã mua)
  items       OrderItem[]
}

model OrderItem {
  id        Int     @id @default(autoincrement())
  name      String  // Lưu cứng Tên sản phẩm lúc mua
  price     Float   // Lưu cứng Giá lúc mua (tránh trường hợp sau này sản phẩm đổi giá)
  quantity  Int
  image     String?

  // Liên kết ngược lại với Đơn hàng
  orderId   Int
  order     Order   @relation(fields: [orderId], references: [id])
}